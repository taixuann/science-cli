# Include only science-cli source files
/*
!/.gitignore
!/src
!/bin
!/scripts
!/pyproject.toml
!/README.md
!/CHANGELOG.md
!/CONTRIBUTING.md
!/LICENSE
!/MIGRATION.md
!/requirements.txt
!/ruff.toml
!/.github
!/.codegraph
!/documentation

# Ignore AGENTS.md files, generated PLAN files at root level, test artifacts
AGENTS.md
**/AGENTS.md
/PLAN-*.md
tests/
test_*.py
theme-previews/

# Python
__pycache__/
*.py[cod]
*.egg-info/
dist/
build/
.eggs/
*.egg
.venv/
venv/
env/

# IDE
.vscode/
.idea/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Environment
.env
.env.*
